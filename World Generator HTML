<!DOCTYPE html>
<html lang="fi">
<head>
<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1.0"/>
<title>World Generator</title>

<style>
    html, body {
        margin: 0;
        overflow: hidden;
        background: #87ceeb;
        font-family: sans-serif;
    }

    canvas {
        display: block;
    }

    #crosshair {
        position: fixed;
        top: 50%;
        left: 50%;
        width: 10px;
        height: 10px;
        transform: translate(-50%, -50%);
        z-index: 5;
        pointer-events: none;
    }

    #crosshair::before,
    #crosshair::after {
        content: "";
        position: absolute;
        background: white;
    }

    #crosshair::before {
        width: 10px;
        height: 2px;
        top: 4px;
        left: 0;
    }

    #crosshair::after {
        width: 2px;
        height: 10px;
        left: 4px;
        top: 0;
    }
</style>
</head>

<body>

<div id="crosshair"></div>

<script type="module">
import * as THREE from 'https://cdn.jsdelivr.net/npm/three@0.160.0/build/three.module.js';

function darken(hex, amount) {
    const c = new THREE.Color(hex);
    c.offsetHSL(0, -amount, 0);
    return c;
}

const skyColor = darken(0x87ceeb, 0.2);

const scene = new THREE.Scene();
scene.background = skyColor;
scene.fog = new THREE.Fog(skyColor, 60, 220);

const camera = new THREE.PerspectiveCamera(
    75,
    window.innerWidth / window.innerHeight,
    0.1,
    1000
);

const renderer = new THREE.WebGLRenderer({
    antialias: false
});

renderer.setSize(window.innerWidth, window.innerHeight);
renderer.setPixelRatio(1);

document.body.appendChild(renderer.domElement);

scene.add(new THREE.AmbientLight(0xffffff, 0.9));

const sun = new THREE.DirectionalLight(0xffffff, 0.7);
sun.position.set(50, 100, 30);
scene.add(sun);

const WATER_LEVEL = 9;
const CHUNK_SIZE = 16;
const RENDER_DISTANCE = 4;

const chunks = new Map();
const waterChunks = new Map();
const clouds = [];

const blockGeometry = new THREE.BoxGeometry(1,1,1);

const materials = {
    grass: new THREE.MeshLambertMaterial({
        color: darken(0x5fb14a, 0.2)
    }),

    dirt: new THREE.MeshLambertMaterial({
        color: darken(0x8a5a2b, 0.2)
    }),

    stone: new THREE.MeshLambertMaterial({
        color: darken(0x888888, 0.2)
    }),

    sand: new THREE.MeshLambertMaterial({
        color: darken(0xd9c27a, 0.2)
    }),

    wood: new THREE.MeshLambertMaterial({
        color: darken(0x6b4423, 0.2)
    }),

    leaves: new THREE.MeshLambertMaterial({
        color: darken(0x2f8f2f, 0.2)
    })
};

const waterMaterial = new THREE.MeshLambertMaterial({
    color: darken(0x3399ff, 0.2),
    transparent: true,
    opacity: 0.82
});

function noise(x, z) {
    return (
        (Math.sin(x * 0.04) + Math.cos(z * 0.05)) * 4 +
        Math.sin((x + z) * 0.025) * 6
    );
}

function getHeight(x, z) {
    let h = Math.floor(noise(x, z) * 0.5 + 10);
    h = Math.max(2, Math.min(18, h));
    return h;
}

function key(x, z) {
    return `${x},${z}`;
}

function createInstanced(list, material, group) {

    if (!list.length) return;

    const mesh = new THREE.InstancedMesh(
        blockGeometry,
        materials[material],
        list.length
    );

    const matrix = new THREE.Matrix4();

    for (let i = 0; i < list.length; i++) {
        const p = list[i];
        matrix.setPosition(p[0], p[1], p[2]);
        mesh.setMatrixAt(i, matrix);
    }

    group.add(mesh);
}

function buildChunk(cx, cz) {

    const k = key(cx, cz);

    if (chunks.has(k)) return;

    const group = new THREE.Group();

    const blocks = {
        grass: [],
        dirt: [],
        stone: [],
        sand: []
    };

    for (let x = 0; x < CHUNK_SIZE; x++) {
        for (let z = 0; z < CHUNK_SIZE; z++) {

            const wx = cx * CHUNK_SIZE + x;
            const wz = cz * CHUNK_SIZE + z;

            const h = getHeight(wx, wz);

            for (let y = 0; y < h; y++) {

                let type;

                if (y === h - 1) {
                    type = h <= WATER_LEVEL ? 'sand' : 'grass';
                }
                else if (y < h - 3) {
                    type = 'stone';
                }
                else {
                    type = 'dirt';
                }

                blocks[type].push([wx, y, wz]);
            }
        }
    }

    for (const type in blocks) {
        createInstanced(blocks[type], type, group);
    }

    generateTrees(group, cx, cz);

    scene.add(group);
    chunks.set(k, group);
}

function generateTrees(group, cx, cz) {

    for (let i = 0; i < 2; i++) {

        const tx = Math.floor(cx * CHUNK_SIZE + Math.random() * CHUNK_SIZE);
        const tz = Math.floor(cz * CHUNK_SIZE + Math.random() * CHUNK_SIZE);

        const h = getHeight(tx, tz);

        if (h < WATER_LEVEL + 1) continue;

        for (let y = 0; y < 3; y++) {

            const trunk = new THREE.Mesh(
                blockGeometry,
                materials.wood
            );

            trunk.position.set(tx, h + y, tz);
            group.add(trunk);
        }

        for (let lx = -1; lx <= 1; lx++) {
            for (let ly = 2; ly <= 4; ly++) {
                for (let lz = -1; lz <= 1; lz++) {

                    if (Math.abs(lx) + Math.abs(lz) === 2 && ly === 4)
                        continue;

                    const leaf = new THREE.Mesh(
                        blockGeometry,
                        materials.leaves
                    );

                    leaf.position.set(
                        tx + lx,
                        h + ly,
                        tz + lz
                    );

                    group.add(leaf);
                }
            }
        }
    }
}

function buildWater(cx, cz) {

    const k = "w_" + key(cx, cz);

    if (waterChunks.has(k)) return;

    const geometry = new THREE.PlaneGeometry(
        CHUNK_SIZE,
        CHUNK_SIZE
    );

    const mesh = new THREE.Mesh(
        geometry,
        waterMaterial
    );

    mesh.rotation.x = -Math.PI / 2;

    mesh.position.set(
        cx * CHUNK_SIZE + CHUNK_SIZE / 2,
        WATER_LEVEL - 1,
        cz * CHUNK_SIZE + CHUNK_SIZE / 2
    );

    scene.add(mesh);
    waterChunks.set(k, mesh);
}

function spawnCloud(x, y, z) {

    const size = 19 + Math.random() * 23;

    const geometry = new THREE.BoxGeometry(
        size,
        size * 0.6,
        size
    );

    const material = new THREE.MeshBasicMaterial({
        color: 0xffffff,
        transparent: true,
        opacity: 0.95
    });

    const cloud = new THREE.Mesh(
        geometry,
        material
    );

    cloud.position.set(x, y, z);

    cloud.scale.set(
        0.95 + Math.random() * 0.3,
        0.55 + Math.random() * 0.2,
        0.95 + Math.random() * 0.3
    );

    scene.add(cloud);

    clouds.push({
        mesh: cloud,
        speed: 0.01 + Math.random() * 0.02
    });
}

for (let i = 0; i < 80; i++) {
    spawnCloud(
        (Math.random() - 0.5) * 400,
        60 + 30 * Math.random(),
        (Math.random() - 0.5) * 400
    );
}

camera.position.set(0, 18, 25);

let yaw = 0;
let pitch = 0;

let velocityY = 0;
let onGround = false;

const keys = {};

window.addEventListener('keydown', e => {
    keys[e.key.toLowerCase()] = true;
});

window.addEventListener('keyup', e => {
    keys[e.key.toLowerCase()] = false;
});

renderer.domElement.addEventListener('click', () => {
    renderer.domElement.requestPointerLock();
});

window.addEventListener('mousemove', e => {

    if (document.pointerLockElement !== renderer.domElement)
        return;

    yaw -= e.movementX * 0.002;
    pitch -= e.movementY * 0.002;

    pitch = Math.max(
        -1.4,
        Math.min(1.4, pitch)
    );
});

function movePlayer() {

    const speed = 0.18;

    if (keys.w) {
        camera.position.x -= Math.sin(yaw) * speed;
        camera.position.z -= Math.cos(yaw) * speed;
    }

    if (keys.s) {
        camera.position.x += Math.sin(yaw) * speed;
        camera.position.z += Math.cos(yaw) * speed;
    }

    if (keys.a) {
        camera.position.x -= Math.cos(yaw) * speed;
        camera.position.z += Math.sin(yaw) * speed;
    }

    if (keys.d) {
        camera.position.x += Math.cos(yaw) * speed;
        camera.position.z -= Math.sin(yaw) * speed;
    }

    const floor = getHeight(
        camera.position.x,
        camera.position.z
    ) + 2;

    if (keys[" "] && onGround) {
        velocityY = 0.35;
        onGround = false;
    }

    velocityY -= 0.02;
    camera.position.y += velocityY;

    if (camera.position.y <= floor) {
        camera.position.y = floor;
        velocityY = 0;
        onGround = true;
    }
}

function updateWorld() {

    const pcx = Math.floor(camera.position.x / CHUNK_SIZE);
    const pcz = Math.floor(camera.position.z / CHUNK_SIZE);

    for (let x = -RENDER_DISTANCE; x <= RENDER_DISTANCE; x++) {
        for (let z = -RENDER_DISTANCE; z <= RENDER_DISTANCE; z++) {

            buildChunk(pcx + x, pcz + z);
            buildWater(pcx + x, pcz + z);
        }
    }

    for (const [k, obj] of chunks) {

        const [cx, cz] = k.split(',').map(Number);

        if (
            Math.abs(cx - pcx) > RENDER_DISTANCE + 1 ||
            Math.abs(cz - pcz) > RENDER_DISTANCE + 1
        ) {
            scene.remove(obj);
            chunks.delete(k);
        }
    }

    for (const [k, obj] of waterChunks) {

        const [cx, cz] = k
            .replace('w_', '')
            .split(',')
            .map(Number);

        if (
            Math.abs(cx - pcx) > RENDER_DISTANCE + 1 ||
            Math.abs(cz - pcz) > RENDER_DISTANCE + 1
        ) {
            scene.remove(obj);
            waterChunks.delete(k);
        }
    }

    for (const c of clouds) {

        c.mesh.position.x += c.speed;

        if (c.mesh.position.x > camera.position.x + 250) {
            c.mesh.position.x -= 500;
        }
    }
}

function animate() {

    requestAnimationFrame(animate);

    camera.rotation.order = 'YXZ';
    camera.rotation.y = yaw;
    camera.rotation.x = pitch;

    movePlayer();
    updateWorld();

    renderer.render(scene, camera);
}

animate();

window.addEventListener('resize', () => {

    camera.aspect =
        window.innerWidth / window.innerHeight;

    camera.updateProjectionMatrix();

    renderer.setSize(
        window.innerWidth,
        window.innerHeight
    );
});
</script>

</body>
</html>
