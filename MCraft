javascript:(()=>{const s=document.createElement('script');s.src='https://cdn.jsdelivr.net/npm/three@0.160.0/build/three.min.js';s.onload=()=>{function desaturate(hex,a){const c=new THREE.Color(hex);c.offsetHSL(0,-a,0);return c}const skyColor=desaturate(0x87ceeb,0.2);const wrap=document.createElement('div');wrap.style='position:fixed;inset:0;z-index:999999;background:#87ceeb';document.body.appendChild(wrap);const scene=new THREE.Scene();scene.fog=new THREE.Fog(skyColor,60,220);scene.background=skyColor;const camera=new THREE.PerspectiveCamera(75,innerWidth/innerHeight,.1,1000);const renderer=new THREE.WebGLRenderer({antialias:false});renderer.setPixelRatio(1);renderer.setSize(innerWidth,innerHeight);renderer.setClearColor(skyColor,1);wrap.appendChild(renderer.domElement);scene.add(new THREE.AmbientLight(0xffffff,.9));const sun=new THREE.DirectionalLight(0xffffff,.7);sun.position.set(50,100,30);scene.add(sun);const cloudGeo=new THREE.BoxGeometry(10,3,10);const cloudMat=new THREE.MeshBasicMaterial({color:0xffffff,transparent:true,opacity:0.8,depthWrite:false});const clouds=new THREE.Group();scene.add(clouds);function makeCloud(x,y,z,s=6){const g=new THREE.Group();const b=Math.floor(5+Math.random()*8);for(let i=0;i<b;i++){const cube=new THREE.Mesh(cloudGeo,cloudMat);cube.position.set(x+(Math.random()-0.5)*s*12,y+(Math.random()-0.5)*3,z+(Math.random()-0.5)*s*12);cube.scale.setScalar(1.5+Math.random()*1.5);g.add(cube)}clouds.add(g)}for(let i=0;i<60;i++){makeCloud((Math.random()-0.5)*800,45+Math.random()*30,(Math.random()-0.5)*800)}const geo=new THREE.BoxGeometry(1,1,1);const mats={grass:new THREE.MeshLambertMaterial({color:desaturate(0x5fb14a,0.2)}),dirt:new THREE.MeshLambertMaterial({color:desaturate(0x8a5a2b,0.2)}),stone:new THREE.MeshLambertMaterial({color:desaturate(0x888888,0.2)}),sand:new THREE.MeshLambertMaterial({color:desaturate(0xd9c27a,0.2)}),water:new THREE.MeshLambertMaterial({color:desaturate(0x3399ff,0.2),transparent:true,opacity:.7})};const CHUNK=16,RENDER=4,WATER=9;const chunks=new Map();function noise(x,z){return(Math.sin(x*.04)+Math.cos(z*.05))*4+Math.sin((x+z)*.025)*6}function key(cx,cz){return cx+','+cz}function makeInstanced(list,mat,group){if(!list.length)return;const mesh=new THREE.InstancedMesh(geo,mats[mat],list.length),m=new THREE.Matrix4();for(let i=0;i<list.length;i++){const p=list[i];m.setPosition(p[0],p[1],p[2]);mesh.setMatrixAt(i,m)}group.add(mesh)}function buildChunk(cx,cz){const k=key(cx,cz);if(chunks.has(k))return;const group=new THREE.Group();const blocks={grass:[],dirt:[],stone:[],sand:[],water:[]};for(let x=0;x<CHUNK;x++)for(let z=0;z<CHUNK;z++){const wx=cx*CHUNK+x,wz=cz*CHUNK+z;let h=Math.floor(noise(wx,wz)*.5+10);h=Math.max(2,Math.min(18,h));const lake=Math.sin(wx*.09)*Math.cos(wz*.09);if(lake>.8)h=Math.min(h,WATER-1);for(let y=0;y<h;y++){let type=y===h-1?(h<=WATER?'sand':'grass'):y<h-3?'stone':'dirt';blocks[type].push([wx,y,wz])}if(h<WATER)blocks.water.push([wx,WATER-1,wz])}for(const t in blocks)makeInstanced(blocks[t],t,group);for(let i=0;i<2;i++){const tx=cx*CHUNK+Math.random()*CHUNK,tz=cz*CHUNK+Math.random()*CHUNK;let h=Math.floor(noise(tx,tz)*.5+10);if(h>=WATER+1){const trunk=new THREE.Mesh(new THREE.BoxGeometry(1,3,1),new THREE.MeshLambertMaterial({color:desaturate(0x6b4423,0.2)}));trunk.position.set(tx,h+1,tz);group.add(trunk);const leaves=new THREE.Mesh(new THREE.BoxGeometry(3,3,3),new THREE.MeshLambertMaterial({color:desaturate(0x2f8f2f,0.2)}));leaves.position.set(tx,h+4,tz);group.add(leaves)}}scene.add(group);chunks.set(k,group)}function updateChunks(){const pcx=Math.floor(camera.position.x/CHUNK),pcz=Math.floor(camera.position.z/CHUNK);for(let x=-RENDER;x<=RENDER;x++)for(let z=-RENDER;z<=RENDER;z++)buildChunk(pcx+x,pcz+z);for(const[k,obj]of chunks){const[cx,cz]=k.split(',').map(Number);if(Math.abs(cx-pcx)>RENDER+1||Math.abs(cz-pcz)>RENDER+1){scene.remove(obj);chunks.delete(k)}}}camera.position.set(0,18,25);let yaw=0,pitch=0,velY=0,onGround=false;const keys={};onkeydown=e=>keys[e.key.toLowerCase()]=1;onkeyup=e=>keys[e.key.toLowerCase()]=0;renderer.domElement.onclick=()=>renderer.domElement.requestPointerLock();onmousemove=e=>{if(document.pointerLockElement===renderer.domElement){yaw-=e.movementX*.002;pitch-=e.movementY*.002;pitch=Math.max(-1.4,Math.min(1.4,pitch))}};function ground(x,z){let h=Math.floor(noise(x,z)*.5+10);const lake=Math.sin(x*.09)*Math.cos(z*.09);if(lake>.8)h=Math.min(h,WATER-1);return h+2}function move(){const speed=.18;if(keys.w){camera.position.x-=Math.sin(yaw)*speed;camera.position.z-=Math.cos(yaw)*speed}if(keys.s){camera.position.x+=Math.sin(yaw)*speed;camera.position.z+=Math.cos(yaw)*speed}if(keys.a){camera.position.x-=Math.cos(yaw)*speed;camera.position.z+=Math.sin(yaw)*speed}if(keys.d){camera.position.x+=Math.cos(yaw)*speed;camera.position.z-=Math.sin(yaw)*speed}const floor=ground(camera.position.x,camera.position.z);if(keys[' ']&&onGround){velY=.35;onGround=false}velY-=.02;camera.position.y+=velY;if(camera.position.y<=floor){camera.position.y=floor;velY=0;onGround=true}}function loop(){requestAnimationFrame(loop);camera.rotation.order='YXZ';camera.rotation.y=yaw;camera.rotation.x=pitch;move();updateChunks();clouds.position.x+=0.01;renderer.render(scene,camera)}updateChunks();loop();addEventListener('resize',()=>{camera.aspect=innerWidth/innerHeight;camera.updateProjectionMatrix();renderer.setSize(innerWidth,innerHeight)})};document.body.appendChild(s)})();
